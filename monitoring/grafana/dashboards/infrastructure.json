{
  "title": "Infrastructure Dashboard",
  "uid": "infra-dashboard",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 2,
      "title": "PostgreSQL Cache Hit Ratio",
      "type": "gauge",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "100 * sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag) by (consumergroup)",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Kafka Messages In/s",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(kafka_topic_partition_current_offset[1m])",
          "legendFormat": "msg/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Brokers",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "kafka_brokers"
        }
      ]
    },
    {
      "id": 6,
      "title": "PostgreSQL Rows Fetched/s",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 16,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched[1m])",
          "legendFormat": "rows/s"
        }
      ]
    }
  ]
}